      "source": [
        "**Calculating  Discount and Link to Uplift**"
      ],
      "metadata": {
        "id": "MDjd8XsrTTTr"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# sort values to prepare for shift\n",
        "promo_df = promo_df.sort_values(['sku', 'day'])\n",
        "\n",
        "\n",
        "promo_df['prev_price'] = promo_df.groupby('sku')['selling_price'].shift(1)\n"
      ],
      "metadata": {
        "id": "bRGYULkKTT0z"
      },
      "execution_count": 36,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#  discount %\n",
        "promo_df['discount_percent'] = (promo_df['prev_price'] - promo_df['selling_price']) / promo_df['prev_price']\n",
        "\n",
        "# valid values\n",
        "promo_df = promo_df[promo_df['discount_percent'].notnull()]\n"
      ],
      "metadata": {
        "id": "KnY4H7A4TrSL"
      },
      "execution_count": 37,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# average discount and average uplift per promo\n",
        "discount_summary = promo_df.groupby('promo_id').agg({\n",
        "    'discount_percent': 'mean',\n",
        "    'uplift': 'mean'\n",
        "}).reset_index()\n"
      ],
      "metadata": {
        "id": "Nnr3oZ3cTu-U"
      },
      "execution_count": 38,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# remove discount % that are negative or too large\n",
        "discount_summary = discount_summary[\n",
        "    (discount_summary['discount_percent'] > 0) &\n",
        "    (discount_summary['discount_percent'] < 1)  # i.e., < 100%\n",
        "]\n"
      ],
      "metadata": {
        "id": "UW2ko9FTWTeQ"
      },
      "execution_count": 39,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "correlation = discount_summary['discount_percent'].corr(discount_summary['uplift'])\n",
        "print(f\"Correlation between discount and uplift: {correlation:.2f}\")\n"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
