    {
      "cell_type": "code",
      "source": [
        "from itertools import product\n",
        "\n",
        "## unique values (day and sku only)\n",
        "unique_days = filtered_df['day'].sort_values().unique()\n",
        "unique_skus = filtered_df['sku'].unique()\n",
        "\n",
        "## creating all combinations (day × sku)\n",
        "full_index = pd.DataFrame(\n",
        "    list(product(unique_days, unique_skus)),\n",
        "    columns=['day', 'sku']\n",
        ")\n",
        "\n",
        "print(\" Full combination index shape:\", full_index.shape)\n",
        "\n",
        "## group actual data (no shop_id)\n",
        "grouped = filtered_df.groupby(['day', 'sku']).agg({\n",
        "    'num_sales': 'sum',\n",
        "    'selling_price': 'mean',\n",
        "    'promo_flag': 'max'\n",
        "}).reset_index()\n",
        "\n",
        "##: merge full index with grouped\n",
        "expanded_df = pd.merge(full_index, grouped, on=['day', 'sku'], how='left')\n",
        "\n",
        "##  fill missing values\n",
        "expanded_df['num_sales'] = expanded_df['num_sales'].fillna(0)\n",
        "expanded_df['selling_price'] = expanded_df['selling_price'].fillna(method='ffill')\n",
        "expanded_df['promo_flag'] = expanded_df['promo_flag'].fillna(0).astype(int)\n",
        "\n",
        "print(\" Final expanded dataset shape:\", expanded_df.shape)\n",
        "expanded_df.head()"
      ],
